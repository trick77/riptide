# Secrets consumed by scripts/onboard-repos.py.
# Copy to .env (or pass via --env-file) and fill in real values. Do NOT commit
# the populated file. Precedence: process env > cwd .env > --env-file.

# HTTP access token for the Bitbucket Data Center REST API. Needs repo-read
# and repo-admin (webhook write) on every repo listed in the onboarding JSON.
BITBUCKET_TOKEN=

# Raw team API key — paste the *exact* token byte-for-byte, including any
# trailing `=` padding. Same string used in argocd-notifications-secret under
# `riptide-token-<team>`. NOT the sha256 hash stored in team-keys.json — that
# form cannot be used as a Bearer. The value travels over the wire as
# `Authorization: Bearer <RIPTIDE_TEAM_KEY>`; riptide hashes it server-side
# and compares against its stored hashes. Rotate via: onboard-repos.py
# --remove, then a fresh onboard.
RIPTIDE_TEAM_KEY=

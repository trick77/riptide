# Secrets consumed by scripts/onboard_repo.py.
# Copy to .env (or pass via --env-file) and fill in real values. Do NOT commit
# the populated file. Precedence: process env > cwd .env > --env-file.

# HTTP access token for the Bitbucket Data Center REST API. Needs repo-read
# and repo-admin (webhook write) on every repo listed in the onboarding JSON.
BITBUCKET_TOKEN=

# Plaintext team API key registered with the running riptide service. Programmed
# into the BBS webhook as `Authorization: Bearer <key>` so riptide accepts the
# inbound calls. Rotate via: onboard_repo.py --remove, then a fresh onboard.
RIPTIDE_TEAM_KEY=

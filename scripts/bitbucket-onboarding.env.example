# Secrets consumed by scripts/bitbucket_onboarding.py.
# Copy to .env (or pass via --env-file) and fill in real values. Do NOT commit
# the populated file. Precedence: --env-file > cwd .env > process env.

# HTTP access token for the Bitbucket Data Center REST API. Needs repo-read
# and repo-admin (webhook write) on every repo listed in the onboarding JSON.
BITBUCKET_TOKEN=

# Team's `bitbucket` HMAC secret — the value stored under
# `<team>.bitbucket` in team-keys.json. Each source has its own per-team
# secret in the new schema:
#
#   {
#     "<team>": {
#       "bitbucket": "<this-value>",
#       "argocd":    "<argocd-bearer>",
#       "jenkins":   "<jenkins-bearer>"
#     }
#   }
#
# The script writes it into the BBS webhook's `configuration.secret`
# field. BBS uses it to sign each delivery with HMAC-SHA256 and sends
# `X-Hub-Signature: sha256=<hex>`. Riptide validates the signature on
# `POST /webhooks/bitbucket/{team}` and 401s on mismatch.
#
# When fetching from a Kubernetes Secret, pipe through `base64 -d`:
# `oc get secret -o jsonpath='{.data.X}'` returns the base64-wrapped form.
# Pasting that directly results in the wrong value on the wire.
#
# Rotate via: bitbucket_onboarding.py --remove, then a fresh onboard with
# the new value.
RIPTIDE_TEAM_KEY=

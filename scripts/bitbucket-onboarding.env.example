# Secrets consumed by scripts/bitbucket_onboarding.py.
# Copy to .env (or pass via --env-file) and fill in real values. Do NOT commit
# the populated file. Precedence: process env > cwd .env > --env-file.

# HTTP access token for the Bitbucket Data Center REST API. Needs repo-read
# and repo-admin (webhook write) on every repo listed in the onboarding JSON.
BITBUCKET_TOKEN=

# Raw team API key — same value stored in team-keys.json and in
# argocd-notifications-secret under `riptide-token-<team>`. Paste it
# byte-for-byte, including any trailing `=` padding.
#
# Important: when fetching from any Kubernetes Secret, pipe through
# `base64 -d`. `oc get secret -o jsonpath='{.data.X}'` returns the
# base64-wrapped form — pasting that directly results in the wrong value
# on the wire and a 401 from riptide.
#
#   oc -n argocd get secret argocd-notifications-secret \
#     -o jsonpath='{.data.riptide-token-<team>}' | base64 -d
#
# The script writes it into the BBS webhook's top-level `credentials` block
# (`{username: <team>, password: RIPTIDE_TEAM_KEY}`). BBS forwards it on the
# wire as `Authorization: Basic <b64(team:RIPTIDE_TEAM_KEY)>`. Rotate via:
# bitbucket_onboarding.py --remove, then a fresh onboard.
RIPTIDE_TEAM_KEY=

# Template for the riptide-collector-secrets Secret.
# Copy to /tmp/secret.env, fill in real values, then:
#   oc create secret generic riptide-collector-secrets \
#       --namespace=$NS \
#       --from-env-file=/tmp/secret.env \
#       --dry-run=client -o yaml | oc apply -f -
#   shred -u /tmp/secret.env
#
# Postgres is provisioned externally — riptide-collector does NOT manage the database.
# Supply a connection URL pointing at the existing cluster Postgres instance.

RIPTIDE_DB_URL=postgresql+asyncpg://USER:PASSWORD@DB_HOST:5432/riptide

# Per-team webhook bearer keys are NOT in this Secret. They live in a separate
# Secret `riptide-collector-team-keys` mounted as a file. See
# `openshift/shared/team-keys.json.example` for the format and provisioning.
